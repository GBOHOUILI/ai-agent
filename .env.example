# ══════════════════════════════════════════════════════════════
#   Zero-to-One AI — Configuration des clés API
#   by Eldo-Moréo GBOHOUILI · github.com/GBOHOUILI/ai-agent
# ══════════════════════════════════════════════════════════════
#
# MULTI-TOKEN POOL : ajoute _2, _3... pour multiplier les quotas
# Exemple : GEMINI_API_KEY=clé1   GEMINI_API_KEY_2=clé2
# → Si la clé 1 atteint son quota, rotation automatique vers la 2
#
# Ordre de priorité : Claude > Gemini > Mistral > Groq > Cohere > OpenRouter > Ollama
# ══════════════════════════════════════════════════════════════

# ── GEMINI (Google) ─── GRATUIT ──────────────────────────────
# → aistudio.google.com/app/apikey
# 15 req/min · 1M tokens/jour · 3 comptes = 3x les quotas
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# ── GROQ ─── GRATUIT (très rapide) ───────────────────────────
# → console.groq.com → API Keys
# LLaMA 3.3 70B · 14,400 req/jour gratuit
GROQ_API_KEY=
GROQ_API_KEY_2=

# ── MISTRAL ─── GRATUIT (meilleur sur le code) ───────────────
# → platform.mistral.ai → API Keys
# mistral-small-latest · free tier généreux
MISTRAL_API_KEY=
MISTRAL_API_KEY_2=

# ── OPENROUTER ─── GRATUIT (50+ modèles) ─────────────────────
# → openrouter.ai → Keys
# Accès à GPT-4, Claude, Llama via une seule clé
OPENROUTER_API_KEY=
OPENROUTER_API_KEY_2=

# ── COHERE ─── GRATUIT ────────────────────────────────────────
# → cohere.com → API Keys
# command-r-plus · excellent pour l'analyse de docs
COHERE_API_KEY=

# ── CLAUDE (Anthropic) ─── PAYANT (meilleure qualité) ────────
# → console.anthropic.com → API Keys
# Meilleur modèle pour le code complexe
CLAUDE_API_KEY=
CLAUDE_API_KEY_2=
CLAUDE_API_KEY_3=
ANTHROPIC_API_KEY=

# ── OLLAMA ─── LOCAL (zéro clé, zéro internet) ───────────────
# → ollama.ai → installer Ollama puis : ollama pull llama3.2
# Aucune clé nécessaire — tourne sur ta machine
# OLLAMA_HOST=http://localhost:11434   (défaut)
# OLLAMA_MODEL=llama3.2               (défaut)
# OLLAMA_FIRST=true                   (utiliser Ollama en priorité)

# ── ANALYTICS (Supabase) ─── OPTIONNEL ───────────────────────
# → supabase.com → ton projet → Settings → API
# Activé seulement si tu as dit "oui" au setup
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...

# ── DEBUG ─────────────────────────────────────────────────────
# DEBUG=true
